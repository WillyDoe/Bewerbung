<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Einsatzgebiet-Zuordnung: Brush-Keys mit Dark-Farben aus Colors.xaml -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource DunkelgrauBlau}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Weiß}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Hellgrau}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource GrauBlau}"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="{StaticResource Dunkelgrau}"/>
    <SolidColorBrush x:Key="TitleBarHoverBrush" Color="{StaticResource DunkelgrauHell}"/>
    <SolidColorBrush x:Key="StatusInactiveBrush" Color="{StaticResource GrauMittel}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource RotPastell}"/>
    <SolidColorBrush x:Key="BorderBlueAccentBrush" Color="{StaticResource GrauBlauHell}"/>


    <!-- Settings Menu Item -->
    <SolidColorBrush x:Key="SettingsMenuItemTextBrush" Color="{StaticResource Weiß}"/>
    <SolidColorBrush x:Key="SettingsMenuItemSelectedBrush" Color="{StaticResource TeiYellow}"/>
    <SolidColorBrush x:Key="SettingsMenuItemHoverBrush" Color="{StaticResource TeiYellowPastel}"/>
    <SolidColorBrush x:Key="SettingsMenuItemSelectedTextBrush" Color="{StaticResource Schwarz}"/>

    <!-- Window-Stil für Dark Mode -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource TeiYellowPastelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource TeiYellow}"/>

    <!-- Settings ComboBox -->
    <SolidColorBrush x:Key="SettingsComboBoxBorderBrush" Color="{StaticResource TeiYellowPastel}"/>
    <SolidColorBrush x:Key="SettingsComboBoxBackgroundBrush" Color="{StaticResource TeiYellowPastelSanft}"/>
    <SolidColorBrush x:Key="SettingsComboBoxArrowIconBrush" Color="{StaticResource TeiYellow}"/>

    <!-- Settings Text Input / Password Input Focused Brush-->
    <SolidColorBrush x:Key="SettingsControlFocusedBorderBrush" Color="{StaticResource TeiYellowPastel}"/>
    <SolidColorBrush x:Key="SettingsControlFocusedLabelBrush" Color="{StaticResource TeiYellowPastel}"/>
</ResourceDictionary>
