<Application x:Class="tei_penService_ui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:tei_penService_ui"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Reihenfolge wichtig: Colors → Brushes → Typography → Controls → Theme-Slot (wird zur Laufzeit geswappt) -->
                <ResourceDictionary Source="Assets/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Assets/Styles/Brushes.xaml"/>
                <ResourceDictionary Source="Assets/Styles/Typography.xaml"/>
                <ResourceDictionary Source="Assets/Styles/Controls/Controls.xaml"/>
                <ResourceDictionary Source="Controls/AppWide/PenControl/PenControlBlueprint.xaml"/>
                <ResourceDictionary Source="Assets/Styles/LightMode.xaml"/>
                <ResourceDictionary Source="Assets/Styles/Calendar/CalendarView.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
