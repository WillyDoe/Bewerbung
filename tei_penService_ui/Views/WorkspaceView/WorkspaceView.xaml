        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="0,0,0,20"
              Panel.ZIndex="50">
            <Grid.Resources>
                <Style x:Key="WorkspaceToolbarButtonStyle" TargetType="Button">
                    <EventSetter Event="PreviewMouseLeftButtonDown"
                                 Handler="WorkspaceToolbarButton_PreviewMouseLeftButtonDown"/>
                    <EventSetter Event="MouseEnter"
                                 Handler="WorkspaceToolbarButton_MouseEnter"/>
                    <EventSetter Event="MouseLeave"
                                 Handler="WorkspaceToolbarButton_MouseLeave"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Width" Value="44"/>
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource TeiCyanBrush}"/>
                    <Setter Property="Tag" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="{TemplateBinding Tag}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                        <Ellipse x:Name="RippleEllipse"
                                                 Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                 Height="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                 Fill="{TemplateBinding BorderBrush}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 Opacity="0"
                                                 IsHitTestVisible="False"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="RippleScaleTransform" ScaleX="0" ScaleY="0"/>
                                                    <TranslateTransform x:Name="RippleTranslateTransform" X="0" Y="0"/>
                                                </TransformGroup>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="WorkspaceToolbarLeftButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource WorkspaceToolbarButtonStyle}">
                    <Setter Property="Tag" Value="11,0,0,11"/>
                </Style>

                <Style x:Key="WorkspaceToolbarMiddleButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource WorkspaceToolbarButtonStyle}"/>

                <Style x:Key="WorkspaceToolbarRightButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource WorkspaceToolbarButtonStyle}">
                    <Setter Property="Tag" Value="0,11,11,0"/>
                </Style>
            </Grid.Resources>

            <ToggleButton x:Name="ToolbarToggleButton"
                          Width="30"
                          Height="24"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,52"
                          Background="Transparent"
                          BorderBrush="Transparent"
                          BorderThickness="0"
                          Cursor="Hand"
                          IsChecked="True"
                          ToolTip="Leiste ein-/ausklappen">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <TextBlock x:Name="ToolbarToggleIcon"
                                   Text="&#xE70E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Black"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToolbarToggleIcon" Property="Text" Value="&#xE70D;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolbarToggleIcon" Property="Foreground" Value="{DynamicResource TeiCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
                <ToggleButton.Triggers>
                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ToolbarSlideTransform"
                                                 Storyboard.TargetProperty="Y"
                                                 To="0"
                                                 Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ToolbarPanel"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.25"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ToolbarSlideTransform"
                                                 Storyboard.TargetProperty="Y"
                                                 To="90"
                                                 Duration="0:0:0.38">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ToolbarPanel"
                                                               Storyboard.TargetProperty="Opacity">
                                    <LinearDoubleKeyFrame KeyTime="0:0:0.18" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.38" Value="0">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <QuadraticEase EasingMode="EaseIn"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ToggleButton.Triggers>
            </ToggleButton>

            <Border x:Name="ToolbarPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="White"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="11"
                    Opacity="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToolbarSlideTransform" Y="0"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.22"
                                      Color="Black"/>
                </Border.Effect>
                <Border Margin="3"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <StackPanel Orientation="Horizontal">
                            <Button x:Name="CreateScratchpadCell"
                                    Style="{StaticResource WorkspaceToolbarLeftButtonStyle}"
                                    ToolTip="Schmierblatt erstellen">
                                <TextBlock Text="&#xE70B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </Button>

                            <Border Width="1" Background="Black"/>

                            <Button x:Name="CreateFileCell"
                                    Style="{StaticResource WorkspaceToolbarMiddleButtonStyle}"
                                    ToolTip="Datei erstellen"
                                    Click="CreateFileButton_Click">
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="17"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </Button>

                            <Border Width="1" Background="Black"/>

                            <Button x:Name="CreateFolderCell"
                                    Style="{StaticResource WorkspaceToolbarMiddleButtonStyle}"
                                    ToolTip="Ordner erstellen"
                                    Click="CreateFolderButton_Click">
                                <TextBlock Text="&#xE838;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </Button>

                            <Border Width="1" Background="Black"/>

                            <Button x:Name="CameraCell"
                                    Style="{StaticResource WorkspaceToolbarMiddleButtonStyle}"
                                    ToolTip="Kamera">
                                <TextBlock Text="&#xE722;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </Button>

                            <Border Width="1" Background="Black"/>

                            <Button x:Name="MicrophoneCell"
                                    Style="{StaticResource WorkspaceToolbarRightButtonStyle}"
                                    ToolTip="Mikrofon">
                                <TextBlock Text="&#xE720;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </Button>
                        </StackPanel>
                </Border>
            </Border>
        </Grid>

