<UserControl x:Class="tei_penService_ui.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:tei_penService_ui.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent"
             Loaded="WorkspaceView_Loaded"
             SizeChanged="WorkspaceView_SizeChanged"
             Unloaded="WorkspaceView_Unloaded">
  <Grid>
      <Grid.Resources>
          <Style x:Key="WorkspaceTabListBoxItemStyle" TargetType="ListBoxItem">
              <Setter Property="Padding" Value="8,4"/>
              <Setter Property="Margin" Value="0,0,4,0"/>
              <Style.Triggers>
                  <Trigger Property="IsSelected" Value="True">
                      <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                  </Trigger>
              </Style.Triggers>
          </Style>
      </Grid.Resources>
       <Grid Margin="4">
           <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="*"/>
           </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                  BorderThickness="0,0,0,1"
                  Padding="0,0,0,4"
                  Margin="0,0,0,4">
              <DockPanel LastChildFill="True">
                  <ListBox x:Name="MainViewTabListBox"
                           DockPanel.Dock="Left"
                           SelectionChanged="MainViewTabListBox_OnSelectionChanged"
                           PreviewMouseLeftButtonDown="MainViewTabListBox_OnPreviewMouseLeftButtonDown"
                           PreviewMouseMove="MainViewTabListBox_OnPreviewMouseMove"
                           DragOver="MainViewTabListBox_OnDragOver"
                           Drop="MainViewTabListBox_OnDrop"
                           AllowDrop="True"
                           Background="Transparent"
                           BorderThickness="0">
                      <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                      </ListBox.ItemsPanel>
                      <ListBox.ItemContainerStyle>
                          <StaticResource ResourceKey="WorkspaceTabListBoxItemStyle"/>
                      </ListBox.ItemContainerStyle>
                      <ListBox.ItemTemplate>
                          <DataTemplate>
                              <StackPanel Orientation="Horizontal">
                                  <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <Button Content="×"
                                          Width="22"
                                          Height="22"
                                          Padding="0"
                                          VerticalAlignment="Center"
                                          Click="CloseMainViewTabButton_Click"
                                          Tag="{Binding}"
                                          ToolTip="Tab schließen"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}">
                                      <Button.Template>
                                          <ControlTemplate TargetType="Button">
                                              <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                          </ControlTemplate>
                                      </Button.Template>
                                      <Button.Style>
                                          <Style TargetType="Button">
                                              <Setter Property="Visibility" Value="Collapsed"/>
                                              <Style.Triggers>
                                                  <DataTrigger Binding="{Binding CanClose}" Value="True">
                                                      <Setter Property="Visibility" Value="Visible"/>
                                                  </DataTrigger>
                                              </Style.Triggers>
                                          </Style>
                                      </Button.Style>
                                  </Button>
                              </StackPanel>
                          </DataTemplate>
                      </ListBox.ItemTemplate>
                  </ListBox>

                  <ListBox x:Name="TabListBox"
                           SelectionChanged="TabListBox_OnSelectionChanged"
                           PreviewMouseLeftButtonDown="TabListBox_OnPreviewMouseLeftButtonDown"
                           PreviewMouseMove="TabListBox_OnPreviewMouseMove"
                           DragOver="TabListBox_OnDragOver"
                           Drop="TabListBox_OnDrop"
                           AllowDrop="True"
                           Background="Transparent"
                           BorderThickness="0">
                      <ListBox.ItemsPanel>
                          <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                      </ListBox.ItemsPanel>
                      <ListBox.ItemContainerStyle>
                          <StaticResource ResourceKey="WorkspaceTabListBoxItemStyle"/>
                      </ListBox.ItemContainerStyle>
                      <ListBox.ItemTemplate>
                          <DataTemplate DataType="{x:Type models:WorkspaceDocumentTabState}">
                              <StackPanel Orientation="Horizontal">
                                  <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                  <Button Content="×"
                                          Width="22"
                                          Height="22"
                                          Padding="0"
                                          VerticalAlignment="Center"
                                          Click="CloseTabButton_Click"
                                          Tag="{Binding}"
                                          ToolTip="Tab schließen"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}">
                                      <Button.Template>
                                          <ControlTemplate TargetType="Button">
                                              <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                          </ControlTemplate>
                                      </Button.Template>
                                  </Button>
                              </StackPanel>
                          </DataTemplate>
                      </ListBox.ItemTemplate>
                  </ListBox>
              </DockPanel>
          </Border>

           <DockPanel x:Name="BasisHost" Grid.Row="1">
               <Canvas x:Name="DesktopCanvas"
                       MinHeight="320"
                       Background="Transparent"
                       MouseMove="DesktopCanvas_MouseMove"
                       MouseLeftButtonUp="DesktopCanvas_MouseLeftButtonUp"
                       MouseLeftButtonDown="DesktopCanvas_MouseLeftButtonDown"/>
           </DockPanel>

          <Grid x:Name="EditorChrome" Grid.Row="1" Visibility="Collapsed">
               <ScrollViewer x:Name="WorkspaceScroll"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Disabled"
                             Background="Transparent">
                   <Border x:Name="WorkspaceA5PageHost"
                           Background="Transparent"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch">
                       <Viewbox x:Name="WorkspaceA5Viewbox"
                                Stretch="Fill"
                                SnapsToDevicePixels="True">
                           <InkCanvas x:Name="WorkspaceInkCanvas"
                                      EditingMode="None"
                                      VerticalAlignment="Top"
                                      Background="{DynamicResource BackgroundBrush}"/>
                       </Viewbox>
                   </Border>
               </ScrollViewer>
          </Grid>

           <Grid x:Name="CalendarHost" Grid.Row="1" Visibility="Collapsed">
               <Border Background="{DynamicResource BackgroundBrush}"
                       BorderBrush="{DynamicResource BorderBrush}"
                       BorderThickness="1"
                       CornerRadius="8"/>

               <Grid Margin="16">
                   <Grid.ColumnDefinitions>
                       <ColumnDefinition x:Name="CalendarSidebarColumn" Width="0"/>
                       <ColumnDefinition Width="12"/>
                       <ColumnDefinition Width="*"/>
                   </Grid.ColumnDefinitions>

                   <Border x:Name="CalendarSidebarPanel"
                           Grid.Column="0"
                           Visibility="Collapsed"
                           Padding="0"
                           Style="{StaticResource CalendarCardBorderStyle}"
                           Background="{DynamicResource TeiBluePastelSanftBrush}"
                           VerticalAlignment="Stretch">
                       <ScrollViewer VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="16"
                                     VerticalAlignment="Stretch">
                       <Grid>
                           <Grid.RowDefinitions>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="12"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="16"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="16"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                               <RowDefinition Height="8"/>
                               <RowDefinition Height="Auto"/>
                           </Grid.RowDefinitions>

                           <TextBlock Grid.Row="0"
                                      Text="Kalender"
                                      Style="{StaticResource CalendarPanelTitleTextStyle}"
                                      VerticalAlignment="Center"/>

                           <Calendar x:Name="CalendarSidebarMiniCalendar"
                                     Grid.Row="2"
                                     HorizontalAlignment="Center"
                                     SelectionMode="SingleDate"
                                     IsTodayHighlighted="True"/>

                           <TextBlock Grid.Row="4"
                                      Text="Meine Kalender"
                                      Style="{StaticResource CalendarPanelSubTitleTextStyle}"/>

                           <StackPanel Grid.Row="6">
                               <CheckBox x:Name="CalendarCheckAlleKalender"
                                         Content="Alle Kalender"
                                         IsChecked="True"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                               <CheckBox x:Name="CalendarCheckSchule"
                                         Content="Schule"
                                         IsChecked="True"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                               <CheckBox x:Name="CalendarCheckPrivat"
                                         Content="Privat"
                                         IsChecked="False"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                           </StackPanel>

                           <Button Grid.Row="8"
                                   Content="Kalender erstellen"
                                   Click="CalendarCreateButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>
                           <Button Grid.Row="10"
                                   Content="Kalender bearbeiten"
                                   Click="CalendarEditButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>
                           <Button Grid.Row="12"
                                   Content="Kalender löschen"
                                   Click="CalendarDeleteButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>

                           <TextBlock Grid.Row="14"
                                      Text="Meine Kategorien"
                                      Style="{StaticResource CalendarPanelSubTitleTextStyle}"/>

                           <StackPanel Grid.Row="16">
                               <CheckBox x:Name="CalendarCategoryCheckHausaufgabe"
                                         Content="Hausaufgabe"
                                         IsChecked="True"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                               <CheckBox x:Name="CalendarCategoryCheckPrufung"
                                         Content="Prüfung"
                                         IsChecked="True"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                               <CheckBox x:Name="CalendarCategoryCheckPersoenlichesZiel"
                                         Content="Persönliches Ziel"
                                         IsChecked="True"
                                         Style="{StaticResource CalendarSidebarCheckBoxStyle}"/>
                           </StackPanel>

                           <Button Grid.Row="18"
                                   Content="Kategorie erstellen"
                                   Click="CalendarCategoryCreateButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>
                           <Button Grid.Row="20"
                                   Content="Kategorie bearbeiten"
                                   Click="CalendarCategoryEditButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>
                           <Button Grid.Row="22"
                                   Content="Kategorie löschen"
                                   Click="CalendarCategoryDeleteButton_Click"
                                   Style="{StaticResource CalendarSidebarActionButtonStyle}"/>
                       </Grid>
                       </ScrollViewer>
                   </Border>

                   <Grid x:Name="CalendarContentHost" Grid.Column="2">
                       <Grid.RowDefinitions>
                           <RowDefinition Height="Auto"/>
                           <RowDefinition Height="12"/>
                           <RowDefinition Height="*"/>
                       </Grid.RowDefinitions>

                   <Border Grid.Row="0"
                           Padding="12,10"
                           Style="{StaticResource CalendarCardBorderStyle}"
                           Background="{DynamicResource TeiCyanPastelSanftBrush}">
                       <Grid>
                           <Grid.ColumnDefinitions>
                               <ColumnDefinition Width="Auto"/>
                               <ColumnDefinition Width="12"/>
                               <ColumnDefinition Width="Auto"/>
                               <ColumnDefinition Width="8"/>
                               <ColumnDefinition Width="Auto"/>
                               <ColumnDefinition Width="*"/>
                               <ColumnDefinition Width="Auto"/>
                           </Grid.ColumnDefinitions>

                           <Button x:Name="CalendarHamburgerButton"
                                   Grid.Column="0"
                                   Width="36"
                                   Height="36"
                                   ToolTip="Kalender-Menü ein- oder ausklappen"
                                   Click="CalendarHamburgerButton_Click"
                                   Style="{StaticResource CalendarIconToolButtonStyle}">
                               <TextBlock Text="&#xE700;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="16"
                                          Foreground="{DynamicResource TextBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                           </Button>

                           <TextBlock x:Name="CalendarMonthText"
                                      Grid.Column="2"
                                      VerticalAlignment="Center"
                                      FontSize="{StaticResource FontSizeL}"
                                      FontWeight="{StaticResource FontWeightSemiBold}"
                                      Foreground="{DynamicResource TextBrush}"
                                      Text="Januar"/>

                           <StackPanel Grid.Column="4"
                                       Orientation="Horizontal"
                                       VerticalAlignment="Center">
                               <TextBlock VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Foreground="{DynamicResource BorderBrush}"
                                          Text="|"/>
                               <Button x:Name="CalendarYearBackButton"
                                       Width="28"
                                       Height="28"
                                       Margin="0,0,2,0"
                                       ToolTip="Vorheriges Jahr"
                                       Click="CalendarYearBackButton_Click"
                                       Style="{StaticResource CalendarIconToolButtonStyle}">
                                   <TextBlock Text="&#xE76B;"
                                              FontFamily="Segoe MDL2 Assets"
                                              Foreground="{DynamicResource TextBrush}"/>
                               </Button>
                               <TextBlock x:Name="CalendarYearText"
                                          VerticalAlignment="Center"
                                          Margin="4,0"
                                          FontSize="{StaticResource FontSizeL}"
                                          FontWeight="{StaticResource FontWeightSemiBold}"
                                          Foreground="{DynamicResource TextBrush}"
                                          Text="2026"/>
                               <Button x:Name="CalendarYearForwardButton"
                                       Width="28"
                                       Height="28"
                                       Margin="2,0,2,0"
                                       ToolTip="Nächstes Jahr"
                                       Click="CalendarYearForwardButton_Click"
                                       Style="{StaticResource CalendarIconToolButtonStyle}">
                                   <TextBlock Text="&#xE76C;"
                                              FontFamily="Segoe MDL2 Assets"
                                              Foreground="{DynamicResource TextBrush}"/>
                               </Button>
                               <Button x:Name="CalendarYearDropdownButton"
                                       Width="28"
                                       Height="28"
                                       Margin="2,0,0,0"
                                       ToolTip="Jahresauswahl"
                                       Click="CalendarYearDropdownButton_Click"
                                       Style="{StaticResource CalendarIconToolButtonStyle}">
                                   <TextBlock Text="&#xE70D;"
                                              FontFamily="Segoe MDL2 Assets"
                                              Foreground="{DynamicResource TextBrush}"/>
                               </Button>
                           </StackPanel>

                           <Border Grid.Column="6"
                                   Padding="3"
                                   CornerRadius="6"
                                   Background="{DynamicResource TeiBluePastelSanftBrush}"
                                   BorderBrush="{DynamicResource BorderBrush}"
                                   BorderThickness="1"
                                   VerticalAlignment="Center">
                           <StackPanel Orientation="Horizontal">
                               <Button x:Name="CalendarDayModeButton"
                                       Content="Tag"
                                       Click="CalendarDayModeButton_Click"
                                       Style="{StaticResource CalendarViewModeButtonStyle}"/>
                               <Button x:Name="CalendarWeekModeButton"
                                       Content="Woche"
                                       Margin="2,0,2,0"
                                       Click="CalendarWeekModeButton_Click"
                                       Style="{StaticResource CalendarViewModeButtonStyle}"/>
                               <Button x:Name="CalendarMonthModeButton"
                                       Content="Monat"
                                       Click="CalendarMonthModeButton_Click"
                                       Style="{StaticResource CalendarViewModeButtonStyle}"/>
                           </StackPanel>
                           </Border>
                       </Grid>
                   </Border>

                   <Popup x:Name="CalendarYearDropdownPanel"
                          Grid.RowSpan="3"
                          PlacementTarget="{Binding ElementName=CalendarYearDropdownButton}"
                          Placement="Bottom"
                          StaysOpen="False"
                          AllowsTransparency="True"
                          PopupAnimation="Fade">
                       <Border Width="130"
                               MaxHeight="220"
                               Margin="0,6,0,0"
                               Style="{StaticResource CalendarCardBorderStyle}">
                           <ListBox x:Name="CalendarYearListBox"
                                    BorderThickness="0"
                                    ScrollViewer.ScrollChanged="CalendarYearListBox_OnScrollChanged"
                                    SelectionChanged="CalendarYearListBox_OnSelectionChanged"
                                    ItemContainerStyle="{StaticResource CalendarYearListBoxItemStyle}"/>
                       </Border>
                   </Popup>

                   <Border Grid.Row="2"
                           Padding="12"
                           Style="{StaticResource CalendarCardBorderStyle}">
                       <Grid>
                           <Grid x:Name="DayViewHost" Visibility="Collapsed">
                               <Grid.RowDefinitions>
                                   <RowDefinition Height="Auto"/>
                                   <RowDefinition Height="*"/>
                               </Grid.RowDefinitions>
                               <TextBlock Text="Tagesansicht"
                                          Style="{StaticResource CalendarViewSectionTitleStyle}"/>
                               <ScrollViewer Grid.Row="1"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled">
                                   <UniformGrid Rows="24" Columns="1" MinHeight="720">
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="00:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="01:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="02:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="03:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="04:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="05:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="06:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="07:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="08:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="09:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="10:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="11:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="12:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="13:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="14:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="15:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="16:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="17:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="18:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="19:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="20:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="21:00"/></Border>
                                       <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="22:00"/></Border>
                                       <Border BorderThickness="0"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="6,4" Text="23:00"/></Border>
                                   </UniformGrid>
                               </ScrollViewer>
                           </Grid>

                           <Grid x:Name="WeekViewHost" Visibility="Collapsed">
                               <Grid.RowDefinitions>
                                   <RowDefinition Height="Auto"/>
                                   <RowDefinition Height="*"/>
                               </Grid.RowDefinitions>
                               <TextBlock Text="Wochenansicht"
                                          Style="{StaticResource CalendarViewSectionTitleStyle}"/>
                               <Grid Grid.Row="1">
                                   <Grid.RowDefinitions>
                                       <RowDefinition Height="Auto"/>
                                       <RowDefinition Height="*"/>
                                   </Grid.RowDefinitions>

                                   <ScrollViewer x:Name="WeekViewBodyScrollViewer"
                                                 Grid.Row="1"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled">
                                   <Grid MinHeight="960">
                                       <Grid.ColumnDefinitions>
                                           <ColumnDefinition Width="66"/>
                                           <ColumnDefinition Width="*"/>
                                       </Grid.ColumnDefinitions>

                                       <Border Grid.Column="0" Style="{StaticResource CalendarTimeColumnBackgroundStyle}">
                                       <UniformGrid Rows="24" Columns="1">
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="00:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="01:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="02:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="03:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="04:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="05:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="06:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="07:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="08:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="09:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="10:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="11:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="12:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="13:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="14:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="15:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="16:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="17:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="18:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="19:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="20:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="21:00"/></Border>
                                           <Border BorderThickness="1,0,1,1" BorderBrush="{DynamicResource BorderBrush}"><TextBlock Style="{StaticResource CalendarTimeLabelTextStyle}" Margin="4,2" HorizontalAlignment="Right" Text="22:00"/></Border>
