       <Button x:Name="CalendarButton"
               Width="52"
                Height="52"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,28"
                BorderThickness="1"
                Foreground="Black"
                Cursor="Hand"
               Panel.ZIndex="50"
               Click="CalendarButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource TeiGreenPastelSanftBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource TeiGreenBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CalendarButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="26">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6"
                                              ShadowDepth="1"
                                              Direction="315"
                                              Opacity="0.30"
                                              Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CalendarButtonBorder" Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock x:Name="CalendarButtonIcon"
                       Text="&#xE787;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="20">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TeiGreenBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Button>
