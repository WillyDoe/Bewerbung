<UserControl x:Class="tei_penService_ui.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:tei_penService_ui.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Abmelden-Button: oben rechts, nur sichtbar wenn angemeldet -->
        <Button x:Name="AbmeldenButton"
                Style="{DynamicResource AbmeldenButtonStyle}"
                Content="Abmelden"
                ToolTip="Abmelden"
                FontSize="11"
                Click="AbmeldenButton_Click"/>

        <!-- Logo + Buttons: zentriert, feste Position -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    x:Name="LogoContainer"
                    Margin="0,-180,0,0">
            <Image Source="/tei_penService_ui;component/Assets/Images/ico/tei_logo_96.ico"
                   Width="96"
                   Height="96"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,15"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        x:Name="ButtonContainer">
                <controls:StartWindowButton x:Name="PairDeviceButton" x:FieldModifier="public"
                                            IconPathData="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                            ButtonText="tei Pen verbinden"
                                            Margin="0,0,15,0"/>
                <controls:StartWindowButton x:Name="BluetoothButton" x:FieldModifier="public"
                                            IconPathData="M17.71 7.71L12 2h-1v7.59L6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 11 14.41V22h1l5.71-5.71-4.3-4.29 4.3-4.29zM13 3.83l1.88 1.88L13 7.59V3.83zm1.88 10.46L13 16.17v-3.76l1.88 1.88z"
                                            ButtonText="Bluetooth aktivieren"
                                            Margin="0,0,15,0"/>
                <controls:StartWindowButton x:Name="StartWithoutPenButton" x:FieldModifier="public"
                                            IconPathData="M8 5v14l11-7z"
                                            ButtonText="ohne Stift starten"/>
            </StackPanel>
        </StackPanel>

        <!-- Tab-Leiste + Inhalt: direkt unter Button-Zeile, zwei Bereiche nebeneinander als Tabs -->
        <StackPanel Grid.Row="0"
                    x:Name="PenListSectionContainer" x:FieldModifier="public"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,0"
                    Background="Transparent">
            <!-- Tab-Überschriften: ganze Zeile, nebeneinander, klickbar; keine zusätzlichen Rahmen -->
            <Border x:Name="TabHeaderRow"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,0"
                    Padding="0"
                    Background="Transparent">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="1"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TabHeaderAvailable"
                            Grid.Row="0" Grid.Column="0"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="8,6,8,6"
                            MouseLeftButtonDown="TabHeaderAvailable_MouseLeftButtonDown"
                            MouseEnter="TabHeaderAvailable_MouseEnter"
                            MouseLeave="TabHeader_MouseLeave">
                        <TextBlock x:Name="TabHeaderAvailableText"
                                   Text="Verfügbare Geräte"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TabHeaderPaired"
                            Grid.Row="0" Grid.Column="1"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="8,6,8,6"
                            MouseLeftButtonDown="TabHeaderPaired_MouseLeftButtonDown"
                            MouseEnter="TabHeaderPaired_MouseEnter"
                            MouseLeave="TabHeader_MouseLeave">
                        <TextBlock x:Name="TabHeaderPairedText"
                                   Text="Gekoppelte Geräte"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <!-- Gemeinsame Unterstreichung: gleitet beim Tab-Wechsel (animiert) -->
                    <Border x:Name="TabUnderline"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Height="1"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource TextSecondaryBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="TabUnderlineTransform"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>
            <!-- Inhalt: nur ein Bereich sichtbar (Tab-Logik) -->
            <Grid x:Name="TabContentArea"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,0"
                  ClipToBounds="False">
                <ScrollViewer x:Name="ContentAvailable" x:FieldModifier="public"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="400"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              IsHitTestVisible="True"
                              Visibility="Visible">
                    <ItemsControl x:Name="PenListContainer" x:FieldModifier="public"
                                  HorizontalAlignment="Stretch"
                                  Background="Transparent">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="controls:PenControlBase">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
                <ItemsControl x:Name="PairedPenListContainer" x:FieldModifier="public"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Visibility="Collapsed">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="controls:PenControlBase">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
