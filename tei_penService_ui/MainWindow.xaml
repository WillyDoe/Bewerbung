<Window x:Class="tei_penService_ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tei_penService_ui"
        xmlns:controls="clr-namespace:tei_penService_ui.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title=""
        Icon="Assets\Images\ico\tei_logo_32.ico"
        Height="800" Width="1200"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Background="{DynamicResource BackgroundBrush}" x:Name="MainGrid">
        <Grid.Resources>
            <!-- Einheitliche Title-Bar-Fenster-Buttons: Inhalt exakt vertikal mittig, Hover sichtbar -->
            <Style x:Key="TitleBarWindowButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template"> 
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ChromeBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChromeBorder" Property="Background" Value="{DynamicResource TitleBarHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ChromeBorder" Property="Background" Value="{DynamicResource TitleBarHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar: schmal (32px, vergleichbar mit Cursor); Fenster-Buttons rechts, Logo + Start/Settings linksbündig -->
        <Border Grid.Row="0"
                HorizontalAlignment="Stretch"
                Panel.ZIndex="10"
                Background="{DynamicResource TitleBarBrush}"
                x:Name="TitleBarBorder"
                MinHeight="32"
                Height="32"
                Padding="10,0,8,0"
                ClipToBounds="True"
                SnapsToDevicePixels="True"
                MouseLeftButtonDown="TitleBarBorder_MouseLeftButtonDown">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource TitleBarWindowButtonStyle}"
                            Content="−"
                            FontSize="20"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimieren"/>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource TitleBarWindowButtonStyle}"
                            FontSize="20"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximieren">
                        <Button.Content>
                            <TextBlock Text="□"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="20"
                                       Foreground="{DynamicResource TextBrush}">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="-2"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource TitleBarWindowButtonStyle}"
                            FontSize="20"
                            Click="CloseButton_Click"
                            ToolTip="Schließen">
                        <Button.Content>
                            <TextBlock Text="×"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="20"
                                       Foreground="{DynamicResource TextBrush}">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="-2"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Image Source="/tei_penService_ui;component/Assets/Images/ico/tei_logo_32.ico"
                           Width="18"
                           Height="18"
                           MaxWidth="18"
                           MaxHeight="18"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           SnapsToDevicePixels="True"
                           Margin="0,0,10,0"/>
                    <Button x:Name="HomeButton"
                            Style="{DynamicResource TitleBarWindowButtonStyle}"
                            Click="HomeButton_Click"
                            ToolTip="Zur Startansicht">
                        <TextBlock Text="&#xE80F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="14"/>
                    </Button>
                    <Button x:Name="SettingsButton"
                            Style="{DynamicResource TitleBarWindowButtonStyle}"
                            Click="SettingsButton_Click"
                            ToolTip="Einstellungen">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="14"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid x:Name="ContentChromeInsetHost"
              Grid.Row="1"
              HorizontalAlignment="Stretch"
              ClipToBounds="True">
            <ContentControl x:Name="MainContentHost"
                            Background="Transparent"/>
            <!-- Login-Maske als Overlay: gedimmter StartView, kleines weißes Fenster zentriert -->
            <Border x:Name="LoginOverlay"
                    Visibility="Collapsed"
                    Background="#E6FFFFFF">
                <Grid>
                    <ContentControl x:Name="LoginOverlayContent"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Statusleiste: Gleicher Stil wie Title Bar -->
        <Border Background="{DynamicResource TitleBarBrush}"
                Grid.Row="2"
                HorizontalAlignment="Stretch"
                Panel.ZIndex="20"
                Padding="10,6"
                MinHeight="28"
                x:Name="StatusBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Bluetooth -->
                <Ellipse Grid.Column="0"
                         Width="7"
                         Height="7"
                         Fill="{StaticResource StatusInactiveBrush}"
                         VerticalAlignment="Center"
                         Margin="0,1,2,0"
                         x:Name="BluetoothStatusIndicator"/>
                <TextBlock Text="Bluetooth"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="10"
                            x:Name="StatusText"/>
                
                <!-- Stift verbunden -->
                <Ellipse Grid.Column="2"
                         Width="7"
                         Height="7"
                         Fill="{StaticResource StatusInactiveBrush}"
                         VerticalAlignment="Center"
                         Margin="10,1,2,0"
                         x:Name="PenConnectedStatusIndicator"/>
                <TextBlock Text="Stift verbunden"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="10"/>
                
                <!-- Angemeldet -->
                <Ellipse Grid.Column="4"
                         Width="7"
                         Height="7"
                         Fill="{StaticResource StatusInactiveBrush}"
                         VerticalAlignment="Center"
                         Margin="10,1,2,0"
                         x:Name="LoggedInStatusIndicator"/>
                <TextBlock Text="Angemeldet"
                            Grid.Column="5"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="10"/>
                
                <!-- Dark Mode Toggle Switch rechts -->
                <ToggleButton Grid.Column="7"
                              Style="{StaticResource DarkModeToggleSwitchStyle}"
                              Checked="DarkModeToggle_Checked"
                              Unchecked="DarkModeToggle_Unchecked"
                              x:Name="DarkModeToggleButton"
                              ToolTip="Dark Mode umschalten"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"
                              Margin="0,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
