<UserControl x:Class="tei_penService_ui.Controls.StartWindowButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             Width="120"
             Height="40">
    <Button x:Name="InternalButton"
            Focusable="False"
            Cursor="Hand"
            Click="InternalButton_Click"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="{Binding BackgroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource TitleBarBrush}}"/>
                <Setter Property="Foreground" Value="{Binding ForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=Black}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{Binding BackgroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource TitleBarBrush}}"
                                    BorderThickness="1"
                                    BorderBrush="Transparent"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                    <!-- Icon -->
                                    <Path x:Name="IconPath"
                                          Data="{Binding IconPathData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Fill="{Binding ForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=Black}"
                                          Width="12"
                                          Height="12"
                                          Stretch="Uniform"
                                          Margin="0,2.5,0,5"
                                          HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="ContentTextBlock"
                                               Text="{Binding ButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=Black}"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               TextAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Hover nur wenn Maus darüber und nicht gedrückt; beim Klick kurzes Zurück zum Normal-Design -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsPressed" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource TitleBarHoverBrush}"/>
                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{Binding HoverForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource TeiCyanBrush}}"/>
                                    <Setter TargetName="ContentTextBlock" Property="Foreground" Value="{Binding HoverForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource TeiCyanBrush}}"/>
                                    <Setter TargetName="IconPath" Property="Fill" Value="{Binding HoverForegroundBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource TeiCyanBrush}}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Button.Style>
    </Button>
</UserControl>
