<UserControl x:Class="tei_penService_ui.Controls.LoadingButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             MinWidth="98"
             Cursor="Hand"
             Background="Transparent">
    <Border x:Name="ButtonBorder"
            Background="Transparent"
            BorderBrush="#4D000000"
            BorderThickness="1"
            CornerRadius="6"
            MinWidth="98"
            Padding="{Binding ContentPadding, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='12,4,12,4'}"
            MouseEnter="ButtonBorder_MouseEnter"
            MouseLeave="ButtonBorder_MouseLeave"
            MouseLeftButtonDown="ButtonBorder_MouseLeftButtonDown">
        <Grid MinHeight="16"
              VerticalAlignment="Center">
            <TextBlock x:Name="ButtonTextBlock"
                       Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=''}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       LineHeight="11"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="11"
                       FontWeight="SemiBold"/>
            <Grid x:Name="LoadingIndicator"
                  Width="16"
                  Height="16"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Visibility="Collapsed"
                  IsHitTestVisible="False">
                <Ellipse x:Name="SpinnerEllipse"
                         Width="12"
                         Height="12"
                         Stroke="{DynamicResource TeiGreenBrush}"
                         StrokeThickness="2"
                         RenderTransformOrigin="0.5,0.5"
                         StrokeDashArray="0.65 0.35">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>
        </Grid>
    </Border>
</UserControl>
