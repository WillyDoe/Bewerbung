<UserControl x:Class="tei_penService_ui.Controls.FormularPasswordInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="300">
    <StackPanel Width="{Binding InputWidth, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <TextBlock x:Name="LabelTextBlock"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,4"/>
        <Border x:Name="PasswordInputBorder"
                BorderBrush="{DynamicResource HellgrauBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="Transparent"
                ClipToBounds="True">
            <PasswordBox x:Name="PasswordInputBox"
                        GotFocus="PasswordInputBox_GotFocus"
                        LostFocus="PasswordInputBox_LostFocus"
                        Background="Transparent"
                        Foreground="{DynamicResource TextBrush}"
                        FontSize="14"
                        Padding="12,10"
                        BorderThickness="0"/>
        </Border>
    </StackPanel>
</UserControl>
