<controls:PenControlBase x:Class="tei_penService_ui.Controls.PenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:tei_penService_ui.Controls"
             xmlns:converters="clr-namespace:tei_penService_ui.Converters"
             mc:Ignorable="d"
             Height="40"
             MinHeight="40"
             MaxHeight="40"
             HorizontalAlignment="Stretch"
             ClipToBounds="True">
    <Grid Margin="0,2,0,4"
          Cursor="Hand"
          PreviewMouseLeftButtonDown="PenControlBorder_PreviewMouseLeftButtonDown">
        <Border x:Name="PenControlBorder"
                Background="{DynamicResource TitleBarBrush}"
                BorderThickness="1"
                BorderBrush="Transparent"
                CornerRadius="6"/>
        <Grid x:Name="PenControlGrid"
              Margin="0,2,0,2"
              ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="24"/>
            </Grid.RowDefinitions>
            <!-- NormalView: Name + MAC (fixed), Section3 = RSSI / Verbunden / nicht in Reichweite -->
            <Grid x:Name="NormalView"
                  Grid.Row="0"
                  Margin="8,0,8,0"
                  VerticalAlignment="Center"
                  Visibility="Visible"
                  ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="PenNameTextBlock"
                               Style="{StaticResource PenControlNormalViewContentStyle}"
                               Text="{Binding PenInformation.Name, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Unbekannter Stift'}"
                               LineHeight="12"
                               HorizontalAlignment="Left"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="MacAddressTextBlock"
                               Style="{StaticResource PenControlNormalViewContentStyle}"
                               Text="{Binding PenInformation.MacAddress, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='00:00:00:00:00:00'}"
                               LineHeight="11"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="11"
                               Margin="0"/>
                </StackPanel>
                <Border x:Name="Section3Container"
                        Grid.Column="2"
                        Style="{StaticResource PenControlNormalViewContentStyle}"
                        HorizontalAlignment="Right"
                        ClipToBounds="False">
                    <Grid>
                        <Grid x:Name="RssiBarPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="Auto" MinWidth="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="RssiTextBlock"
                                       Grid.Column="0"
                                       Style="{StaticResource PenControlNormalViewContentStyle}"
                                       Text="{Binding PenInformation.Rssi, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='{}{0} dBm', FallbackValue='-100 dBm'}"
                                       LineHeight="11"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="11"
                                       Margin="0,0,6,0"/>
                            <Border Grid.Column="1"
                                    Width="50"
                                    Height="8"
                                    CornerRadius="4"
                                    Background="{DynamicResource BorderBrush}"
                                    ClipToBounds="True"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                <Rectangle Width="50"
                                           Height="8"
                                           RadiusX="4"
                                           RadiusY="4"
                                           HorizontalAlignment="Left"
                                           RenderTransformOrigin="0,0.5">
                                    <Rectangle.Fill>
                                        <Binding Path="PenInformation.Rssi" RelativeSource="{RelativeSource AncestorType=UserControl}">
                                            <Binding.Converter>
                                                <converters:RssiToColorConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <ScaleTransform ScaleY="1">
                                            <ScaleTransform.ScaleX>
                                                <Binding Path="PenInformation.Rssi" RelativeSource="{RelativeSource AncestorType=UserControl}">
                                                    <Binding.Converter>
                                                        <converters:RssiToFillRatioConverter/>
                                                    </Binding.Converter>
                                                </Binding>
                                            </ScaleTransform.ScaleX>
                                        </ScaleTransform>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="VerbundenTextBlock"
                                   Text="Verbunden"
                                   Visibility="Collapsed"
                                   Style="{StaticResource PenControlNormalViewContentStyle}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="NichtInReichweiteTextBlock"
                                   Text="nicht in Reichweite"
                                   Visibility="Collapsed"
                                   Style="{StaticResource PenControlNormalViewContentStyle}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"/>
                    </Grid>
                </Border>
            </Grid>
            <!-- ConnectView: nur Verfügbare Geräte – Verbinden, Passwort, Trennen -->
            <Grid x:Name="ConnectView"
                  Grid.Row="0"
                  Visibility="Collapsed"
                  Margin="8,0,8,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <controls:LoadingButton x:Name="ConnectLoadingButton"
                                            Text="Verbinden"
                                            AccentBrushKey="TeiGreenBrush"
                                            ContentPadding="12,2,12,2"
                                            MaxHeight="26"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Click="ConnectButton_Click"/>
                    <Grid x:Name="PasswordInputPanel"
                          Visibility="Collapsed"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="PasswordFieldBorder"
                                Grid.Column="0"
                                Width="140"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="Transparent"
                                ClipToBounds="True">
                            <PasswordBox x:Name="PenPasswordBox"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Padding="6,4"
                                         FontSize="11"
                                         MaxLength="32"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         PasswordChar="•"/>
                        </Border>
                        <Border x:Name="PasswordSubmitButton"
                                Grid.Column="1"
                                Margin="6,0,0,0"
                                Padding="8,4"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="4"
                                MouseEnter="PasswordSubmitButton_MouseEnter"
                                MouseLeave="PasswordSubmitButton_MouseLeave"
                                PreviewMouseLeftButtonDown="PasswordSubmitButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="PasswordSubmitButton_PreviewMouseLeftButtonUp"
                                MouseLeftButtonDown="PasswordSubmitButton_Click">
                            <TextBlock x:Name="PasswordSubmitButtonText"
                                       Text="OK"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="Black"/>
                        </Border>
                    </Grid>
                    <controls:LoadingButton x:Name="DisconnectLoadingButton"
                                            Text="Trennen"
                                            AccentBrushKey="StatusErrorBrush"
                                            ContentPadding="12,2,12,2"
                                            MaxHeight="26"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="DisconnectButton_Click"/>
                </Grid>
            </Grid>
            <!-- HoverView: Gekoppelte Geräte = Entfernen + Verbinden/Trennen; Verbunden = nur Trennen -->
            <Grid x:Name="HoverView"
                  Grid.Row="0"
                  Margin="8,0,8,0"
                  VerticalAlignment="Center"
                  Visibility="Collapsed"
                  ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:LoadingButton x:Name="HoverRemoveLoadingButton"
                                        Grid.Column="0"
                                        Text="Entfernen"
                                        AccentBrushKey="StatusErrorBrush"
                                        ContentPadding="12,2,12,2"
                                        MaxHeight="26"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed"
                                        Click="HoverRemoveButton_Click"/>
                <Border x:Name="HoverDisconnectButton"
                        Grid.Column="0"
                        MinWidth="98"
                        Margin="0,1,0,1"
                        Padding="12,4"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderBrush="#4D000000"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed"
                        MouseEnter="DisconnectButton_MouseEnter"
                        MouseLeave="DisconnectButton_MouseLeave"
                        PreviewMouseLeftButtonDown="DisconnectButton_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="DisconnectButton_PreviewMouseLeftButtonUp"
                        MouseLeftButtonDown="DisconnectButton_Click">
                    <TextBlock x:Name="HoverDisconnectButtonText"
                               Text="Trennen"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               LineHeight="11"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <controls:LoadingButton x:Name="HoverConnectLoadingButton"
                                            Text="Verbinden"
                                            AccentBrushKey="TeiGreenBrush"
                                            ContentPadding="12,2,12,2"
                                            MaxHeight="26"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="HoverConnectButton_Click"/>
                    <controls:LoadingButton x:Name="HoverDisconnectLoadingButton"
                                            Text="Trennen"
                                            AccentBrushKey="TeiYellowBrush"
                                            ContentPadding="12,2,12,2"
                                            MaxHeight="26"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="HoverDisconnectButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</controls:PenControlBase>
